generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            BigInt         @id @default(autoincrement())
  email         String         @unique
  password_hash String
  name          String
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt
  enrollments   Enrollment[]
  video_progress VideoProgress[]
  refresh_tokens RefreshToken[]
  certificates   Certificate[]

  @@map("users")
}

model Subject {
  id           String       @id @default(uuid())
  title        String
  slug         String       @unique
  description  String?      @db.Text
  category     String       @default("Engineering")
  is_published Boolean      @default(false)
  is_featured  Boolean      @default(false)
  created_at   DateTime     @default(now())
  updated_at   DateTime     @updatedAt
  sections     Section[]
  enrollments  Enrollment[]
  certificates Certificate[]

  @@map("subjects")
}

model Section {
  id          String   @id @default(uuid())
  subject_id  String
  title       String
  order_index Int
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  subject     Subject  @relation(fields: [subject_id], references: [id], onDelete: Cascade)
  videos      Video[]

  @@index([subject_id, order_index])
  @@unique([subject_id, order_index])
  @@map("sections")
}

model Video {
  id               String          @id @default(uuid())
  section_id       String
  title            String
  description      String?         @db.Text
  youtube_url      String
  order_index      Int
  duration_seconds Int?
  created_at       DateTime        @default(now())
  updated_at       DateTime        @updatedAt
  section          Section         @relation(fields: [section_id], references: [id], onDelete: Cascade)
  progress         VideoProgress[]

  @@index([section_id, order_index])
  @@unique([section_id, order_index])
  @@map("videos")
}

model Enrollment {
  id         String   @id @default(uuid())
  user_id    BigInt
  subject_id String
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id])
  subject    Subject  @relation(fields: [subject_id], references: [id])

  @@unique([user_id, subject_id])
  @@map("enrollments")
}

model VideoProgress {
  id                    String    @id @default(uuid())
  user_id               BigInt
  video_id              String
  last_position_seconds Int       @default(0)
  is_completed          Boolean   @default(false)
  completed_at          DateTime?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt
  user                  User      @relation(fields: [user_id], references: [id])
  video                 Video     @relation(fields: [video_id], references: [id])

  @@unique([user_id, video_id])
  @@map("video_progress")
}

model Certificate {
  id               String   @id @default(uuid())
  user_id          BigInt
  subject_id       String
  certifier_id     String?
  certificate_url  String?
  issued_at        DateTime @default(now())

  user             User     @relation(fields: [user_id], references: [id])
  subject          Subject  @relation(fields: [subject_id], references: [id])

  @@unique([user_id, subject_id])
  @@map("certificates")
}

model RefreshToken {
  id         String    @id @default(uuid())
  user_id    BigInt
  token_hash String
  expires_at DateTime
  revoked_at DateTime?
  created_at DateTime  @default(now())
  user       User      @relation(fields: [user_id], references: [id])

  @@index([user_id, token_hash])
  @@map("refresh_tokens")
}
